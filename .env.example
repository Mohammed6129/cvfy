# =============================================================================
# CVfy — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For Vercel deployment, add these variables in:
#   Project Settings → Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Authentication)
# Get these from: https://supabase.com/dashboard → Project Settings → API
# -----------------------------------------------------------------------------

# Public Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public Supabase anonymous key (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Auth redirect URL (configure in Supabase dashboard):
#   Site URL: https://your-domain.vercel.app
#   Redirect URLs: https://your-domain.vercel.app/auth/callback

# -----------------------------------------------------------------------------
# Anthropic (AI — CV generation, enhancement, ATS check)
# Get your key from: https://console.anthropic.com/
# Server-side only — do NOT prefix with NEXT_PUBLIC_
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=your-anthropic-api-key

# -----------------------------------------------------------------------------
# Moyasar (Payments)
# Get your key from: https://dashboard.moyasar.com/
# Publishable key (pk_live_ or pk_test_) — safe for browser use
# Secret key (sk_live_ or sk_test_) — server-side verification only
# -----------------------------------------------------------------------------

NEXT_PUBLIC_MOYASAR_PUBLISHABLE_KEY=pk_live_your-moyasar-publishable-key
